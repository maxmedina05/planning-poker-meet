# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# Run ./deploy.sh to generate config.js + .firebaserc and deploy to Firebase.

# Google Cloud project number (12-digit number, not the project ID string)
# Found at: Cloud Console → select project → dashboard header "Project number"
CLOUD_PROJECT_NUMBER=YOUR_CLOUD_PROJECT_NUMBER

# Firebase project ID (the string ID, e.g. my-project-12345)
# Found at: Firebase Console → Project settings → General → Project ID
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID

# reCAPTCHA v3 site key (public key — safe to store here)
# Found at: google.com/recaptcha/admin → your site → Site key
RECAPTCHA_V3_SITE_KEY=YOUR_RECAPTCHA_V3_SITE_KEY

# Firebase web app config values
# Found at: Firebase Console → Project settings → Your apps → SDK snippet
FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID
